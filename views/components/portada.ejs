<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portada</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,200..1000;1,200..1000&display=swap"
        rel="stylesheet">

    <style>
        :root {
            /* Color palette - Principal */
            --color-primary-1: #27a1db;
            --color-primary-2: #bd5785;
            --color-primary-3: #d88008;

            /* Color palette - Acentos */
            --color-accent-1: #4b3e7a;
            --color-accent-2: #0075af;
            --color-accent-3: #4c8631;
            --color-accent-4: #fcf1ef;
            --color-accent-5: #2557a4;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: #f0f0f0;
            font-family: 'Nunito', Arial, sans-serif;
            font-weight: 400;
            text-align: center;

        }

        /* Typography - Nunito font weights */
        .nunito-light {
            font-family: 'Nunito', Arial, sans-serif;
            font-weight: 300;
        }

        .nunito-regular {
            font-family: 'Nunito', Arial, sans-serif;
            font-weight: 400;
        }

        .nunito-medium {
            font-family: 'Nunito', Arial, sans-serif;
            font-weight: 500;
        }

        .nunito-semibold {
            font-family: 'Nunito', Arial, sans-serif;
            font-weight: 600;
        }

        .nunito-bold {
            font-family: 'Nunito', Arial, sans-serif;
            font-weight: 700;
        }

        .nunito-extrabold {
            font-family: 'Nunito', Arial, sans-serif;
            font-weight: 800;
        }

        /* Color utility classes */
        .text-primary-1 {
            color: var(--color-primary-1);
        }

        .text-primary-2 {
            color: var(--color-primary-2);
        }

        .text-primary-3 {
            color: var(--color-primary-3);
        }

        .text-accent-1 {
            color: var(--color-accent-1);
        }

        .text-accent-2 {
            color: var(--color-accent-2);
        }

        .text-accent-3 {
            color: var(--color-accent-3);
        }

        .text-accent-4 {
            color: var(--color-accent-4);
        }

        .text-accent-5 {
            color: var(--color-accent-5);
        }

        .bg-primary-1 {
            background-color: var(--color-primary-1);
        }

        .bg-primary-2 {
            background-color: var(--color-primary-2);
        }

        .bg-primary-3 {
            background-color: var(--color-primary-3);
        }

        .bg-accent-1 {
            background-color: var(--color-accent-1);
        }

        .bg-accent-2 {
            background-color: var(--color-accent-2);
        }

        .bg-accent-3 {
            background-color: var(--color-accent-3);
        }

        .bg-accent-4 {
            background-color: var(--color-accent-4);
        }

        img {
            width: 100%;
            height: auto;
        }

        .fZ22 {
            font-size: 22px;
        }

        .fZ20 {
            font-size: 20px;
        }

      

        .portada {
            display: flex;
            flex-direction: column;
            /* align-items: center; */
            /* justify-content: center; */
        }

        .spacer {
            margin-top: 150px; /* Equivalente a 5 <br> aproximadamente */
        }

        /* Utility classes para espaciado */
        .mt-1 { margin-top: 16px; }
        .mt-2 { margin-top: 32px; }
        .mt-3 { margin-top: 48px; }
        .mt-4 { margin-top: 64px; }
        .mt-5 { margin-top: 80px; }
        
        .mb-1 { margin-bottom: 16px; }
        .mb-2 { margin-bottom: 32px; }
        .mb-3 { margin-bottom: 48px; }
        .mb-4 { margin-bottom: 64px; }
        .mb-5 { margin-bottom: 80px; }
    </style>
</head>

<body>

    <div class="portada">


        <div>
            <img src="<%= portadaImage %>">
        </div>
        
        <div class="spacer">

            <h1 class="nunito-semibold  fZ22 text-accent-5"><%= campus %></h1>
            <p class="nunito-semibold fZ22 text-accent-5"><%= code %></p>
            <p class="nunito-light fZ20 text-accent-5"><%= year %></p>
            <p class="nunito-light fZ20 text-accent-5"><%= programName %></p>
        </div>
    </div>

</body>

</html>