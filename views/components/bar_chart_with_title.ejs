<style>
    :root {
        /* Color palette - Principal */
        --primary-blue: #27a1db;
        --primary-pink: #bd5785;
        --primary-orange: #d88008;

        /* Color palette - Acentos */
        --accent-purple: #4b3e7a;
        --accent-light: #fcf1ef;
        --accent-green: #4c8631;


         --color-rojo: #c55c5c;
  --color-naranja: #d88008;
  --color-amarillo: #f4d03f;
  --color-verde: #58a55c; 
    }

    .chart-item {
        text-align: center;
        width: 336px;

    }

.charts-container {
    display: grid;
    grid-template-columns: repeat(2, 336px); /* 2 por fila, mismo ancho que tus items */
    gap: 60px;
    justify-content: center; /* centra el bloque de columnas */
    margin: 40px auto;
}

    .chart-label {
        text-align: center;
        font-size: 20px;
        font-weight: 600;
        color: #666;
        margin-bottom: 20px;
    }

    .chart-wrapper {
        position: relative;
        margin-bottom: 30px;
        align-content: end;
    }

    .header-row {
        display: flex;
        margin-bottom: 8px;
        justify-content: flex-end;
    }

    .header-box {
        width: 45px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 14px;
        margin-right: 0;
        border-radius: 0;
        box-sizing: border-box;
    }

    .header-color-1 {
        background-color: var(--color-rojo);
    }

    .header-color-2 {
        background-color: var(--color-naranja);
    }

    .header-color-3 {
        background-color: var(--color-amarillo);
    }

    .header-color-4 {
        background-color: var(--color-verde);
    }

    .stats-table {
        width: 336px;
        border-collapse: separate;
        border-spacing: 0 5px;
        margin-top: 10px;
        font-size: 14px;
        border-radius: 0;
    }

    .stats-table td {
        padding-top: 4px;
        margin: 0px !important;
    }

    .stats-table td div {
        text-align: center;
        background-color: var(--accent-light);
    }

    .stats-table tbody tr {
        background-color: var(--accent-light);
    }

    .rounded-left {
        border-radius: 0 5px 5px 0;
    }

    .rounded-right {
        border-radius: 5px 0 0 5px;
    }

    canvas {
        display: block;
        box-sizing: border-box;
        height: 200px;
        width: 336px;
    }
</style>

<div class="charts-container">
    <% subjects.forEach(function(subject) { %>
        <div class="chart-item">
            <h2 class="chart-label">
                <%= subject.title %>
            </h2>

            <div class="chart-wrapper">
                <canvas id="<%= subject.chartId %>"></canvas>
            </div>

            <!-- Header -->
            <div class="header-row">
                <% subject.ranges.forEach(function(range, index) { %>
                    <div
                        class="header-box header-color-<%= index + 1 %> <%= index === 0 ? 'rounded-right' : (index === subject.ranges.length - 1 ? 'rounded-left' : '') %>">
                        <%= index + 1 %>
                    </div>
                    <% }); %>
            </div>

            <!-- Stats Table -->
            <table class="stats-table">
                <tbody>
                    <tr>
                        <td class="rounded-right">
                            <div>% Estudiantes</div>
                        </td>
                        <% subject.ranges.forEach(function(range, index) { %>
                            <td <%=index===subject.ranges.length - 1 ? 'class="rounded-left"' : '' %>>
                                <div>
                                    <%= range.percentage %>%
                                </div>
                            </td>
                            <% }); %>
                    </tr>
                    <tr>
                        <td class="rounded-right">
                            <div># Estudiantes</div>
                        </td>
                        <% subject.ranges.forEach(function(range, index) { %>
                            <td <%=index===subject.ranges.length - 1 ? 'class="rounded-left"' : '' %>>
                                <div>
                                    <%= range.count %>
                                </div>
                            </td>
                            <% }); %>
                    </tr>
                </tbody>
            </table>
        </div>
        <% }); %>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // Wait for Chart.js to be available and DOM to be ready
    document.addEventListener('DOMContentLoaded', function () {
        // Check if Chart is available
        if (typeof Chart === 'undefined') {
            console.error('Chart.js is not loaded');
            return;
        }

        // Create charts for each subject
        <% subjects.forEach(function(subject) { %>
            const chartData_<%= subject.chartId.replace(/\s+/g, '_') %> = <%- JSON.stringify(subject.chartData) %>;
            const ctx_<%= subject.chartId.replace(/\s+/g, '_') %> = document.getElementById('<%= subject.chartId %>').getContext('2d');

            const config_<%= subject.chartId.replace(/\s+/g, '_') %> = {
                type: 'bar',
                data: {
                    labels: ['1', '2', '3', '4'],
                    datasets: [{
                        data: chartData_<%= subject.chartId.replace(/\s+/g, '_') %>.values,
                        backgroundColor: ['#c55c5c', '#d88008', '#f4d03f', '#58a55c'],
                        borderWidth: 0,
                        borderRadius: 4,
                        barThickness: 40 
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 100,
                            ticks: {
                                stepSize: 10,
                                font: {
                                    family: 'Nunito',
                                    size: 12
                                },
                                color: '#666'
                            },
                            grid: {
                                color: '#e0e0e0',
                                lineWidth: 1
                            }
                        },
                        x: {
                            ticks: {
                                font: {
                                    family: 'Nunito',
                                    size: 14,
                                    weight: '600'
                                },
                                color: '#666'
                            },
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            };

            new Chart(ctx_<%= subject.chartId.replace(/\s+/g, '_') %>, config_<%= subject.chartId.replace(/\s+/g, '_') %>);
        <% }); %>
    });
</script>