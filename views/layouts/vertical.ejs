<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head', {
        title: title,
        extraCSS: [
            '/api/reports/css/vertical-layout.css'
        ]
    }) %>
    <!-- Chart.js - Load before components -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.min.js"></script>
</head>
<body class="vertical-layout">
    <%- include('../partials/header', {
       
        layout: 'vertical'
    }) %>
    
    <% if (chartTitle) { %>
        <div class="chart-title vertical"><%= chartTitle %></div>
    <% } %> 
    
    <div class="paddingMargen">
        <%- content %>
    </div>
</body>
</html>