# ===============================================
# FORMARTE REPORTS - ENVIRONMENT CONFIGURATION
# ===============================================
# Generated on: 2025-09-19
# 
# IMPORTANT: 
# - Change all secrets in production!
# - Keep this file secure and never commit to version control
# - Add .env to .gitignore

# ===============================================
# SERVER CONFIGURATION
# ===============================================
NODE_ENV=production
PORT=3350
HOST=0.0.0.0

# ===============================================
# AUTHENTICATION & SECURITY
# ===============================================

# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET=formarte-jwt-secret-2025-super-secure-key-min-32-chars-required-for-security

# Legacy API Key (for backwards compatibility)
API_KEY=formarte-reports-2025-api-key-change-in-production

# Podium API Configuration (automatically used by auth service)
# API URL: https://stage-api.plataformapodium.com/api/user/
# No additional config needed - service handles this internally

# ===============================================
# CORS CONFIGURATION
# ===============================================
CORS_ORIGIN=http://localhost:3000,https://api-reports.plataformapodium.com
CORS_CREDENTIALS=true

# For multiple origins, use comma-separated values:
# CORS_ORIGIN=http://localhost:3000,https://app.formarte.com,https://admin.formarte.com

# ===============================================
# RATE LIMITING
# ===============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Explanation:
# - RATE_LIMIT_WINDOW_MS: Time window in milliseconds (900000 = 15 minutes)
# - RATE_LIMIT_MAX_REQUESTS: Max requests per IP per window (100 requests)

# ===============================================
# LOGGING
# ===============================================
LOG_LEVEL=info
LOG_FORMAT=combined

# Available LOG_LEVEL options: error, warn, info, debug
# Available LOG_FORMAT options: combined, common, dev, short, tiny

# ===============================================
# DOCKER & DEPLOYMENT
# ===============================================

# Docker Service Ports
NGINX_PORT=80
NGINX_HTTPS_PORT=443
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana Admin Password (CHANGE IN PRODUCTION!)
GRAFANA_PASSWORD=admin123

# ===============================================
# PUPPETEER CONFIGURATION
# ===============================================
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# For macOS development, comment out PUPPETEER_EXECUTABLE_PATH to use automatic browser detection
# For Docker/Linux containers where Chromium is pre-installed, uncomment the line above
# Set PUPPETEER_SKIP_CHROMIUM_DOWNLOAD to true in Docker containers where Chromium is pre-installed
# Set to false for local development to download Chromium automatically

# ===============================================
# DEVELOPMENT SETTINGS
# ===============================================

# Development Database (if needed in future)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=formarte_reports
# DB_USER=formarte_user
# DB_PASSWORD=formarte_password

# MongoDB Configuration
#MONGODB_URI=mongodb://localhost:27017/arkappformarte_clone_5
# For production with authentication:
MONGO_URI=mongodb://arkdevuser:q1CRB%2A8%252%3Fqk@54.164.38.115:27017/arkdevmongo

# External API Timeouts (milliseconds)
PODIUM_API_TIMEOUT=10000
PDF_GENERATION_TIMEOUT=300000

# File Upload Limits
MAX_FILE_SIZE=50mb
MAX_REQUEST_SIZE=10mb

# ===============================================
# PRODUCTION OVERRIDES
# ===============================================
# When NODE_ENV=production, ensure these are set:

# HTTPS Configuration (production)
# SSL_CERT_PATH=/path/to/certificate.crt
# SSL_KEY_PATH=/path/to/private.key

# Production Database
# DATABASE_URL=postgresql://user:password@host:port/database

# Production JWT Secret (must be 32+ characters)
# JWT_SECRET=your-super-secure-production-jwt-secret-key-with-32-plus-characters

# Production API Key
# API_KEY=your-production-api-key-for-legacy-compatibility

# Production CORS Origins
# CORS_ORIGIN=https://app.formarte.com,https://admin.formarte.com

# ===============================================
# MONITORING & ANALYTICS (Optional)
# ===============================================

# Sentry Error Tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Application Insights (optional)
# APPINSIGHTS_INSTRUMENTATIONKEY=your-app-insights-key

# New Relic (optional)
# NEW_RELIC_LICENSE_KEY=your-new-relic-license-key
# NEW_RELIC_APP_NAME=formarte-reports-service

# ===============================================
# FEATURE FLAGS (Optional)
# ===============================================

# Enable/disable features
ENABLE_WEBSOCKET=true
ENABLE_PDF_CACHING=false
ENABLE_METRICS=false
ENABLE_DEBUG_ROUTES=false

# Report generation limits
MAX_STUDENTS_PER_REPORT=1000
MAX_QUESTIONS_PER_REPORT=500
MAX_CONCURRENT_REPORTS=5


# ===============================================
# DEVELOPMENT NOTES
# ===============================================
# 
# Quick Start:
# 1. Run: npm install
# 2. Run: npm run dev
# 3. Visit: http://localhost:3001/health
# 4. API docs: Check docs/API_ENDPOINTS.md
# 
# Authentication Flow:
# 1. POST /api/auth/login with Podium credentials
# 2. Use returned JWT token in Authorization header
# 3. Access protected endpoints like /api/reports/*
# 
# Docker:
# 1. Run: ./start.sh
# 2. Visit: http://localhost:3001
# 
# Testing:
# 1. Run: ./test-auth.sh
# 2. Check authentication endpoints
# 
# Documentation:
# - API: docs/API_ENDPOINTS.md
# - Auth: docs/AUTHENTICATION.md
# - Architecture: docs/ARCHITECTURE.md
# - Usage: docs/USAGE_EXAMPLES.md

# ===============================================
# END OF CONFIGURATION
# ===============================================
