# Server Configuration
PORT=3001
NODE_ENV=development
HOST=localhost

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
API_KEY=your-secret-api-key
JWT_SECRET=your-jwt-secret

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined